# SERVER CONFIGURATION
PORT=3000
NODE_ENV=development

# AWS CONFIGURATION
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY

# DYNAMODB TABLES
DYNAMODB_TABLE_USERS=quester-users
DYNAMODB_TABLE_TRIPS=quester-trips
DYNAMODB_TABLE_SESSIONS=quester-trip-sessions
DYNAMODB_TABLE_LOGS=quester-audit-logs
DYNAMODB_TABLE_VERSIONS=quester-itinerary-versions

# JWT CONFIGURATION
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRATION=30d

# GCP CONFIGURATION
GCP_CLOUD_FUNCTION_URL=YOUR_GCP_FUNCTION_URL
GCP_API_KEY=YOUR_GCP_API_KEY
GCP_PROJECT_ID=your-gcp-project-id

# SECURITY CONFIGURATION
BCRYPT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=3
LOCKOUT_DURATION_MINUTES=5
